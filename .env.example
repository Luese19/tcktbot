# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ==========================================
# COMPANY CONFIGURATION
# ==========================================
COMPANY_NAME=Your Company Name
COMPANY_EMAIL_DOMAIN=company.com

# ==========================================
# EMAIL/SMTP CONFIGURATION
# ==========================================
# Gmail: Use smtp.gmail.com with App Password (not regular password)
# See: https://myaccount.google.com/apppasswords
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password_16_chars
SMTP_USE_TLS=true
# Email address where Spiceworks tickets are sent
SPICEWORKS_EMAIL=ticketing@company.com

# ==========================================
# ADMIN CONFIGURATION
# ==========================================
# Strong password (minimum 16 characters recommended)
ADMIN_PASSWORD=your_secure_admin_password_16plus_chars
# Comma-separated Telegram user IDs (get from @userinfobot)
ADMIN_USER_IDS=123456789,987654321

# ==========================================
# FIELD VALIDATION LIMITS
# ==========================================
MIN_NAME_LENGTH=2
MAX_NAME_LENGTH=100
MIN_ISSUE_LENGTH=5
MAX_ISSUE_LENGTH=200
MIN_DESCRIPTION_LENGTH=10
MAX_DESCRIPTION_LENGTH=2000

# ==========================================
# FILE UPLOAD LIMITS
# ==========================================
MAX_FILE_SIZE_MB=10
MAX_ATTACHMENTS_PER_TICKET=5

# ==========================================
# CONVERSATION SETTINGS
# ==========================================
CONVERSATION_TIMEOUT_MINUTES=30
MAX_MESSAGE_LENGTH=4000

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Production: INFO  Development: DEBUG
LOG_LEVEL=INFO
# Production: /var/log/ticketingbot/bot.log  Development: ./logs/bot.log
LOG_FILE_PATH=./logs/bot.log

# ==========================================
# GROUP MENTION QUEUE CONFIGURATION
# ==========================================
# Enable group mention feature with sequential ticket creation
QUEUE_ENABLED=false
QUEUE_TIMEOUT_MINUTES=30
REQUEST_TIMEOUT_MINUTES=60
CONCURRENT_TICKET_CREATION=1

# ==========================================
# REACTION-BASED TICKET CREATION
# ==========================================
# Enable/disable reaction-based tickets for IT team
REACTION_TICKET_ENABLED=false
# Comma-separated IT team member user IDs (get from @userinfobot)
IT_TEAM_USER_IDS=123456789,987654321
# Reaction emojis that trigger ticket creation
TICKET_REACTION_TRIGGERS=👍,🎫,✅
